<?xml version="1.0" encoding="UTF-8"?>
<!--
  Use this settings file when your global ~/.m2/settings.xml uses a mirror
  (e.g. paig-dev-dev1 or corporate Nexus) that doesn't have Spring Boot/AI.
  Run: mvn -s settings-standalone.xml clean package
       mvn -s settings-standalone.xml spring-boot:run
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 https://maven.apache.org/xsd/settings-1.0.0.xsd">
  <!-- No <mirrors> section = Maven uses repositories from pom.xml (Central + Spring). -->
</settings>
